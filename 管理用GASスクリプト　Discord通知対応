function applyCellFormatting(s,r,p,g12,pw,pg,ss,as){ 
  try { 
    s.getRange(r, 1).setNumberFormat('yyyy/MM/dd HH:mm:ss'); 
    if(g12<=11.0) s.getRange(r,10).setBackground("#ffcccc"); else if(g12<=11.8) s.getRange(r,10).setBackground("#ffffcc");
