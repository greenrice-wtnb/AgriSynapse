function saveGroupConfigCmd(ss, groupName, ch, auth) {
  if (!groupName || groupName === "-" || groupName === "_NEW_") return;
  let groupSheet = ss.getSheetByName("GROUP_LIST");
  if (!groupSheet) { groupSheet = ss.insertSheet("GROUP_LIST"); groupSheet.appendRow(["GroupName", "Channel", "AUTH_KEY"]); }
  const gData = groupSheet.getDataRange().getValues();
  let gRow = -1;
  for (let i = 1; i < gData.length; i++) { if (String(gData[i][0]).trim() === String(groupName).trim()) { gRow = i + 1; break; } }
  // ★ ガード処理: ch/auth が有効な値の場合のみ書き込む。空欄送信で既存値を消さない。
  const isChValid   = (ch   !== undefined && ch   !== null && String(ch).trim()   !== "");
  const isAuthValid = (auth !== undefined && auth !== null && String(auth).trim() !== "");
  if (gRow !== -1) {
    if (isChValid)   groupSheet.getRange(gRow, 2).setValue(parseInt(ch) || 0);
    if (isAuthValid) groupSheet.getRange(gRow, 3).setValue(String(auth).trim());
  } else {
    groupSheet.appendRow([groupName, isChValid ? (parseInt(ch) || 0) : 0, isAuthValid ? String(auth).trim() : ""]);
  }
}

function saveFieldConfigCmd(ss, id, dry, full, offset, mode, groupName, ch) {
  let logSheet = ss.getSheetByName("Log");
  if (!logSheet) {
    logSheet = ss.insertSheet("Log");
    logSheet.appendRow(["日時", "Field_ID", "Volt", "Level", "Pico_V", "Gate_V", "Gate_Cmd", "Status", "G_Status", "Gate_12V", "RSSI", "S_Err", "Act_St", "Dry", "Full"]);
  }
  // ★ ガード処理: dry/full はupdateLogSheetThreshold内でも検証するが、
  //   呼び出し前に有効チェックして不要な書き込みを抑制する。
  updateLogSheetThreshold(logSheet, id, dry, full);
  
  let idSheet = ss.getSheetByName("ID_LIST");
  if (!idSheet) {
    idSheet = ss.insertSheet("ID_LIST");
    idSheet.appendRow(["Field_ID", "表示名", "送信オフセット", "グループ", "稼働モード", "最終通信", "", "", "", "", "", "", "通信状態"]);
  }
  
  const idData = idSheet.getDataRange().getValues();
  let idRow = -1;
  for (let i = 1; i < idData.length; i++) { if (String(idData[i][0]).trim() === String(id).trim()) { idRow = i + 1; break; } }
  if (idRow !== -1) {
    // ★ ガード処理: 各フィールドが有効な値を持つ場合のみ書き込む。
    //   空欄・null・undefined が送られてきた場合は既存セルを保持し設定値の消失を防ぐ。
    //   （例: setup_gate.htmlからの同期では dry/full/groupName 等が送られないため、
    //     ガードなしでは該当セルが空欄で上書きされてしまう）
    const isOffsetValid = (offset !== undefined && offset !== null && String(offset).trim() !== "");
    const isGroupValid  = (groupName !== undefined && groupName !== null && String(groupName).trim() !== "" && groupName !== "-");
    const isModeValid   = (mode === "RUN" || mode === "STOP");
    if (isOffsetValid) idSheet.getRange(idRow, 3).setValue(parseInt(offset) || 0);
    if (isGroupValid)  idSheet.getRange(idRow, 4).setValue(groupName);
    if (isModeValid)   idSheet.getRange(idRow, 5).setValue(mode);
  }
  return "OK";
}
