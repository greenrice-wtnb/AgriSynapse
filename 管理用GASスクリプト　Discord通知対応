function monitorCommunicationHeartbeat() {
  const ss = SpreadsheetApp.getActiveSpreadsheet(); const idSheet = ss.getSheetByName("ID_LIST"); const sysSheet = ss.getSheetByName("SYSTEM");
  if (!idSheet || !sysSheet) return; if (sysSheet.getRange("A1").getValue() === "STOP" || sysSheet.getRange("B1").getValue() === "OFF") return;
  const now = new Date();
  const data = idSheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    const lastSeen = new Date(data[i][5]);
    const id = data[i][0]; const currentStatus = data[i][12];
    if (!id || String(id).trim() === "" || isNaN(lastSeen.getTime()) || data[i][4] === "STOP") continue;
    const diffMinutes = (now - lastSeen) / (1000 * 60);
    if (diffMinutes > 90) {
      if (currentStatus === "OFFLINE") continue;
      const conf = getNotificationConfig(ss, id);
      if (conf.warn) sendMessagingApiPush("🚨 通信途絶\n圃場ID: " + id + "\n最終通信: " + Math.floor(diffMinutes) + "分前", id);
      idSheet.getRange(i + 1, 13).setValue("OFFLINE");
      const logSheet = ss.getSheetByName("Log");
      if (logSheet) { 
        let tr = -1;
        const ld = logSheet.getDataRange().getValues();
        for(let j=1; j<ld.length; j++){ if(String(ld[j][1]).trim() === String(id).trim()){ tr = j+1; break; } }
        if(tr !== -1) { 
            const prev = ld[tr - 1];
            const lostRow = [ new Date(), id, prev[2], prev[3], prev[4], prev[5], "KEEP", "TIMEOUT", prev[8], prev[9], prev[10], prev[11], "COMM_LOST" ];
            logSheet.getRange(tr, 1, 1, 13).setValues([lostRow]); 
        }
      }
    }
  }
}

function setupWatchdogTrigger() { 
    const triggers = ScriptApp.getProjectTriggers();
    for (let i = 0; i < triggers.length; i++) { if (triggers[i].getHandlerFunction() === "monitorCommunicationHeartbeat") ScriptApp.deleteTrigger(triggers[i]); } 
    ScriptApp.newTrigger("monitorCommunicationHeartbeat").timeBased().everyHours(1).create();
}
